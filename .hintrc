{
  "extends": [
    "development"
  ],
  "hints": {
    "typescript-config/strict": "off",
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off"
      }
    ],
    "axe/forms": [
      "default",
      {
        "label": "off",
        "select-name": "off"
      }
    ],
    "button-type": "off",
    "axe/parsing": [
      "default",
      {
        "duplicate-id-active": "off",
        "duplicate-id": "off"
      }
    ],
    "axe/text-alternatives": [
      "default",
      {
        "image-alt": "off"
      }
    ],
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "height: fit-content",
          "width: fit-content",
          "appearance",
          "appearance: auto"
        ]
      }
    ],
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "input[type=datetime-local]",
          "input[type=date]"
        ]
      }
    ],
    "meta-viewport": "off",
    "no-inline-styles": "off",
    "typescript-config/consistent-casing": "off"
  }
}